# Si esta carpeta se publica bajo un subpath (no es la raíz del vhost), ajusta RewriteBase a ese path,
# por ejemplo: RewriteBase /PuntoDeVenta/PuntoDeVenta/
# (debe coincidir con FDP_BASE_PATH en el servidor si usas override).

RewriteEngine On
RewriteBase /
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html

RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.*)$ $1.php
	